*.o
.gradle/
build/
result
.DS_Store

# Built wasm test fixtures/modules are generated by `make resources`, not committed.
# (sqlite3.wasm is large; CI builds it. Tiny hand-checked fixtures may be committed
#  explicitly with `git add -f` if a build-free CI path is ever wanted.)
engine/src/test/resources/modules/*.wasm
engine/src/test/resources/modules/*.mp3
fixtures/*.wasm

# Third-party source drops fetched by the Makefile (sqlite amalgamation, etc.)
third_party/

# MkDocs build output (the docs site is built into site/, deployed by CI).
site/
